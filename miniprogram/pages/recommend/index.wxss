.recommend-page {
  background: #f7f6f2;
  min-height: 100vh;
}

.top-bar {
  margin-bottom: 18rpx;
  border-radius: 30rpx;
  background: linear-gradient(150deg, #fcfbf8, #f4f0e6);
  border-color: #e6dfce;
}

.app-name {
  font-size: 22rpx;
  color: #7d7566;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.top-title {
  margin-top: 6rpx;
  font-size: 42rpx;
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "Songti SC", serif;
}

.meta-row {
  margin-top: 8rpx;
}

.control-row {
  margin-top: 14rpx;
  gap: 12rpx;
}

.flavor-chip,
.mode-chip {
  min-width: 190rpx;
  text-align: center;
  font-size: 22rpx;
  background: #f1ebe0;
  border-color: #d8cfbc;
}

.flavor-chip {
  flex: 1;
}

.mode-chip {
  flex: 1;
}

.source-line {
  display: inline-block;
  font-size: 21rpx;
  color: #6b6b6b;
  background: rgba(198, 169, 105, 0.14);
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
}

.drift-hint {
  margin-top: 10rpx;
  color: #7a7467;
}

.cards-wrap {
  transition: opacity 220ms ease, transform 220ms ease;
}

.cards-enter {
  opacity: 1;
  transform: translateY(0rpx);
}

.cards-exit {
  opacity: 0;
  transform: translateY(10rpx);
}

.poker-swiper {
  height: 888rpx;
}

.poker-card {
  height: 852rpx;
  border-radius: 30rpx;
  overflow: hidden;
  position: relative;
  background: #eceae4;
  box-shadow: 0 20rpx 44rpx rgba(40, 43, 39, 0.18);
  animation: cardIn 220ms ease both;
  transition: transform 220ms ease, opacity 220ms ease, filter 220ms ease;
}

.card-active {
  transform: scale(1);
  opacity: 1;
  filter: saturate(1);
}

.card-side {
  transform: scale(0.965);
  opacity: 0.9;
  filter: saturate(0.85);
}

.poker-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.poker-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(31, 31, 31, 0.08), rgba(22, 24, 22, 0.78));
}

.poker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  color: #ffffff;
}

.poker-title {
  font-size: 42rpx;
  font-weight: 700;
  margin-top: 14rpx;
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "Songti SC", serif;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
}

.poker-dish {
  margin-top: 8rpx;
  font-size: 25rpx;
  opacity: 0.96;
}

.poker-tags {
  margin-top: 14rpx;
}

.tag.dark {
  background: rgba(242, 239, 231, 0.2);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.poker-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.poker-reason {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.quote-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.quote-text {
  font-size: 24rpx;
  line-height: 1.5;
}

.quote-from {
  margin-top: 6rpx;
  font-size: 20rpx;
  opacity: 0.88;
}

.card-indicator {
  text-align: center;
  color: #6b6b6b;
  font-size: 24rpx;
  margin: 14rpx 0 8rpx;
}

.skeleton-wrap {
  margin-bottom: 6rpx;
}

.skeleton-card {
  overflow: hidden;
  position: relative;
  background: #f9f7f1;
}

.skeleton-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -120rpx;
  width: 120rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0));
  animation: shimmer 1.4s infinite;
}

@keyframes shimmer {
  0% {
    left: -140rpx;
  }
  100% {
    left: 100%;
  }
}

.skeleton-line,
.skeleton-button {
  background: #ece8dd;
  border-radius: 14rpx;
}

.skeleton-title {
  width: 58%;
  height: 32rpx;
}

.skeleton-subtitle {
  width: 36%;
  height: 24rpx;
  margin-top: 14rpx;
}

.skeleton-reason {
  width: 86%;
  height: 22rpx;
  margin-top: 16rpx;
}

.skeleton-button {
  flex: 1;
  height: 72rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.rank-badge {
  display: inline-block;
  width: fit-content;
  background: rgba(198, 169, 105, 0.24);
  color: #fffaf0;
  border: 1rpx solid rgba(224, 198, 142, 0.62);
  border-radius: 999rpx;
  padding: 5rpx 13rpx;
  font-size: 20rpx;
}

.selected-badge {
  display: inline-block;
  width: fit-content;
  background: rgba(96, 174, 125, 0.24);
  color: #effff5;
  border: 1rpx solid rgba(126, 212, 157, 0.62);
  border-radius: 999rpx;
  padding: 5rpx 13rpx;
  font-size: 20rpx;
}

.action-row {
  margin-top: 16rpx;
  gap: 16rpx;
}

.bottom-actions {
  margin-top: 10rpx;
  margin-bottom: 0;
}

.bottom-actions-secondary {
  margin-top: 10rpx;
  margin-bottom: 4rpx;
}

.selected-share-wrap {
  margin-top: 10rpx;
}

.selected-share-hint {
  margin: 0 4rpx 8rpx;
  color: #6b6b6b;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.selected-share-row {
  margin-top: 0;
}

.selected-share-row .btn-secondary {
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-card {
  margin-top: 6rpx;
}

.action-success {
  box-shadow: 0 0 0 2rpx rgba(198, 169, 105, 0.35) inset;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(16rpx) scale(0.992);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
