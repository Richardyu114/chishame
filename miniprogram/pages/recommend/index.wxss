button {
  line-height: 1.2;
  transition: transform 120ms ease, filter 120ms ease, box-shadow 120ms ease;
}

.btn-pressed {
  transform: scale(0.97);
  filter: brightness(0.96);
}

.header-card {
  margin-bottom: 18rpx;
}

.radius-chip {
  min-width: 146rpx;
  text-align: center;
}

.source-line {
  margin-top: 14rpx;
  display: inline-block;
  font-size: 22rpx;
  color: #b45309;
  background: #ffedd5;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.cards-wrap {
  transition: opacity 160ms ease, transform 160ms ease;
}

.cards-enter {
  opacity: 1;
  transform: translateY(0rpx);
}

.cards-exit {
  opacity: 0;
  transform: translateY(10rpx);
}

.restaurant-card {
  padding-bottom: 20rpx;
  animation: cardIn 170ms ease both;
  will-change: transform, opacity;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(12rpx) scale(0.995);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.name-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rank-badge {
  display: inline-block;
  width: fit-content;
  background: #fff7ed;
  color: #c2410c;
  border: 1rpx solid #fdba74;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
}

.restaurant-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.distance-pill {
  font-size: 22rpx;
  color: #4b5563;
  background: #f3f4f6;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.action-row {
  margin-top: 16rpx;
  gap: 16rpx;
}

.bottom-actions {
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}
