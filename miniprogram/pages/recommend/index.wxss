button {
  line-height: 1.2;
  transition: transform 120ms ease, filter 120ms ease, box-shadow 120ms ease;
}

button[disabled] {
  opacity: 0.62;
  filter: saturate(0.75);
}

.btn-pressed {
  transform: scale(0.97);
  filter: brightness(0.96);
}

.header-card {
  margin-bottom: 18rpx;
}

.radius-chip {
  min-width: 146rpx;
  text-align: center;
}

.source-line {
  margin-top: 14rpx;
  display: inline-block;
  font-size: 22rpx;
  color: #b45309;
  background: #ffedd5;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.cards-wrap {
  transition: opacity 160ms ease, transform 160ms ease;
}

.cards-enter {
  opacity: 1;
  transform: translateY(0rpx);
}

.cards-exit {
  opacity: 0;
  transform: translateY(10rpx);
}

.skeleton-wrap {
  margin-bottom: 6rpx;
}

.skeleton-card {
  overflow: hidden;
  position: relative;
}

.skeleton-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -120rpx;
  width: 120rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,0.7), rgba(255,255,255,0));
  animation: shimmer 1.4s infinite;
}

@keyframes shimmer {
  0% { left: -140rpx; }
  100% { left: 100%; }
}

.skeleton-line,
.skeleton-pill,
.skeleton-button {
  background: #f1f5f9;
  border-radius: 14rpx;
}

.skeleton-title {
  width: 58%;
  height: 32rpx;
}

.skeleton-subtitle {
  width: 36%;
  height: 24rpx;
  margin-top: 14rpx;
}

.skeleton-tags {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.skeleton-pill {
  width: 100rpx;
  height: 34rpx;
  border-radius: 999rpx;
}

.skeleton-pill.short {
  width: 76rpx;
}

.skeleton-reason {
  width: 86%;
  height: 22rpx;
  margin-top: 16rpx;
}

.skeleton-button {
  flex: 1;
  height: 72rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.restaurant-card {
  padding-bottom: 20rpx;
  animation: cardIn 170ms ease both;
  will-change: transform, opacity;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(12rpx) scale(0.995);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.name-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rank-badge {
  display: inline-block;
  width: fit-content;
  background: #fff7ed;
  color: #c2410c;
  border: 1rpx solid #fdba74;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
}

.restaurant-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.distance-pill {
  font-size: 22rpx;
  color: #4b5563;
  background: #f3f4f6;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.action-row {
  margin-top: 16rpx;
  gap: 16rpx;
}

.bottom-actions {
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}
