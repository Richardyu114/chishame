button {
  line-height: 1.2;
  transition: transform 120ms ease, filter 120ms ease, box-shadow 120ms ease;
}

button[disabled] {
  opacity: 0.62;
  filter: saturate(0.75);
}

.btn-pressed {
  transform: scale(0.97);
  filter: brightness(0.96);
}

.recommend-page {
  background: #ffffff;
  min-height: 100vh;
}

.top-bar {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
}

.flavor-chip {
  min-width: 190rpx;
  text-align: center;
  font-size: 22rpx;
}

.source-line {
  margin-top: 2rpx;
  display: inline-block;
  font-size: 22rpx;
  color: #6b7280;
  background: #f8fafc;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.cards-wrap {
  transition: opacity 160ms ease, transform 160ms ease;
}

.cards-enter {
  opacity: 1;
  transform: translateY(0rpx);
}

.cards-exit {
  opacity: 0;
  transform: translateY(10rpx);
}

.poker-swiper {
  height: 880rpx;
}

.poker-card {
  height: 850rpx;
  border-radius: 26rpx;
  overflow: hidden;
  position: relative;
  background: #f3f4f6;
  box-shadow: 0 14rpx 30rpx rgba(17, 24, 39, 0.18);
  animation: cardIn 170ms ease both;
}

.poker-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.poker-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.72));
}

.poker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 26rpx;
  color: #ffffff;
}

.poker-title {
  font-size: 42rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.poker-dish {
  margin-top: 8rpx;
  font-size: 26rpx;
  opacity: 0.95;
}

.poker-tags {
  margin-top: 14rpx;
}

.tag.dark {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.poker-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.poker-reason {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.quote-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.quote-text {
  font-size: 24rpx;
  line-height: 1.5;
}

.quote-from {
  margin-top: 6rpx;
  font-size: 20rpx;
  opacity: 0.88;
}

.card-indicator {
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
  margin: 12rpx 0 6rpx;
}

.skeleton-wrap {
  margin-bottom: 6rpx;
}

.skeleton-card {
  overflow: hidden;
  position: relative;
}

.skeleton-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -120rpx;
  width: 120rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0));
  animation: shimmer 1.4s infinite;
}

@keyframes shimmer {
  0% { left: -140rpx; }
  100% { left: 100%; }
}

.skeleton-line,
.skeleton-button {
  background: #f1f5f9;
  border-radius: 14rpx;
}

.skeleton-title {
  width: 58%;
  height: 32rpx;
}

.skeleton-subtitle {
  width: 36%;
  height: 24rpx;
  margin-top: 14rpx;
}

.skeleton-reason {
  width: 86%;
  height: 22rpx;
  margin-top: 16rpx;
}

.skeleton-button {
  flex: 1;
  height: 72rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.rank-badge {
  display: inline-block;
  width: fit-content;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
}

.action-row {
  margin-top: 16rpx;
  gap: 16rpx;
}

.bottom-actions {
  margin-top: 8rpx;
  margin-bottom: 0;
}

.bottom-actions-secondary {
  margin-top: 10rpx;
  margin-bottom: 4rpx;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(12rpx) scale(0.995);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
