<view class="container recommend-page">
  <view class="card top-bar">
    <view class="title top-title">今天吃什么</view>
    <view class="subtitle">{{timeSlot}} · 先定吃什么，再自己选店</view>

    <view class="row meta-row">
      <view class="source-line">{{activeMealMode}}模式 · 结构化推荐</view>
    </view>

    <view class="subtitle drift-hint">{{flavorDriftHint}}</view>

    <view class="row control-row">
      <view class="btn-secondary flavor-chip {{successAction === 'flavor' ? 'action-success' : ''}}" bindtap="switchFlavor">口味：{{preferredFlavor}}</view>
      <view class="btn-secondary mode-chip {{successAction === 'mode' ? 'action-success' : ''}}" bindtap="switchMealMode">餐别：{{mealMode}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="skeleton-wrap">
    <block wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="card skeleton-card">
        <view class="skeleton-line skeleton-title"></view>
        <view class="skeleton-line skeleton-subtitle"></view>
        <view class="skeleton-line skeleton-reason"></view>
        <view class="row action-row">
          <view class="skeleton-button"></view>
          <view class="skeleton-button"></view>
        </view>
      </view>
    </block>
  </view>

  <view wx:elif="{{cards.length > 0}}" class="cards-wrap {{cardsVisible ? 'cards-enter' : 'cards-exit'}}">
    <swiper
      class="poker-swiper"
      current="{{currentCardIndex}}"
      bindchange="onCardChange"
      previous-margin="36rpx"
      next-margin="36rpx"
      circular="{{cards.length > 1}}"
      duration="280"
      skip-hidden-item-layout="{{true}}"
    >
      <block wx:for="{{cards}}" wx:key="id" wx:for-index="idx">
        <swiper-item>
          <view class="poker-card {{idx === currentCardIndex ? 'card-active' : 'card-side'}}" style="animation-delay: {{idx * 24}}ms;">
            <image class="poker-bg" src="{{item.image}}" mode="aspectFill"></image>
            <view class="poker-mask"></view>

            <view class="poker-content">
              <text class="rank-badge">{{idx === 0 ? '今日首推' : idx === 1 ? '稳妥备选' : '灵感备选'}}</text>
              <view class="poker-title">{{item.title}}</view>
              <view class="poker-dish">{{item.dishLine}}</view>

              <view class="poker-tags">
                <block wx:for="{{item.tags}}" wx:key="*this">
                  <text class="tag dark">{{item}}</text>
                </block>
              </view>

              <view class="poker-meta">估算 {{item.calories}} kcal · {{item.mealMode || activeMealMode}}策略</view>
              <view class="poker-reason">{{item.reasons.join(' · ')}}</view>

              <view class="quote-box">
                <view class="quote-text">“{{item.quote.text}}”</view>
                <view class="quote-from">{{item.quote.from}}</view>
              </view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>

    <view class="card-indicator">{{currentCardIndex + 1}} / {{cards.length}}</view>

    <view class="row action-row bottom-actions">
      <button
        class="btn-secondary {{pressedAction === 'refresh' ? 'btn-pressed' : ''}} {{successAction === 'refresh' ? 'action-success' : ''}}"
        style="flex:1;"
        data-action="refresh"
        disabled="{{loading}}"
        loading="{{loading && busyAction === 'refresh'}}"
        bindtouchstart="onPressAction"
        bindtouchend="onReleaseAction"
        bindtouchcancel="onReleaseAction"
        bindtap="refreshCards"
      >再翻一页</button>
      <button
        class="btn-secondary {{pressedAction === 'flavor' ? 'btn-pressed' : ''}} {{successAction === 'flavor' ? 'action-success' : ''}}"
        style="flex:1;"
        data-action="flavor"
        disabled="{{loading}}"
        loading="{{loading && busyAction === 'flavor'}}"
        bindtouchstart="onPressAction"
        bindtouchend="onReleaseAction"
        bindtouchcancel="onReleaseAction"
        bindtap="switchFlavor"
      >换个风味</button>
    </view>

    <view class="row action-row bottom-actions-secondary">
      <button
        class="btn-primary {{pressedAction === 'choose' ? 'btn-pressed' : ''}} {{successAction === 'choose' ? 'action-success' : ''}}"
        style="flex:1;"
        data-action="choose"
        disabled="{{loading}}"
        bindtouchstart="onPressAction"
        bindtouchend="onReleaseAction"
        bindtouchcancel="onReleaseAction"
        bindtap="pickCurrent"
      >今天吃这个</button>
      <button
        class="btn-primary {{pressedAction === 'random' ? 'btn-pressed' : ''}} {{successAction === 'random' ? 'action-success' : ''}}"
        style="flex:1;"
        data-action="random"
        disabled="{{loading}}"
        bindtouchstart="onPressAction"
        bindtouchend="onReleaseAction"
        bindtouchcancel="onReleaseAction"
        bindtap="randomOne"
      >交给口福</button>
    </view>
  </view>
</view>
