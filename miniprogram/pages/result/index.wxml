<view class="container result-page" wx:if="{{meal}}">
  <view class="card result-hero">
    <image class="cover" src="{{meal.image}}" mode="aspectFill"></image>
    <view class="mask"></view>
    <view class="hero-content">
      <view class="hero-badge">今日定案</view>
      <view class="meal-title">{{meal.title}}</view>
      <view class="subtitle hero-subtitle">{{meal.dishLine}}</view>
    </view>
  </view>

  <view class="card">
    <view class="title section-title">这一餐结构</view>
    <view class="info-row">
      <view class="info-key">主食</view>
      <view class="info-value">{{meal.staple}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">蛋白</view>
      <view class="info-value">{{meal.protein}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">蔬菜</view>
      <view class="info-value">{{meal.veggie}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">补充</view>
      <view class="info-value">{{meal.extra}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">估算热量</view>
      <view class="info-value">{{meal.calories}} kcal</view>
    </view>
  </view>

  <view class="card">
    <view class="title section-title">今日语录</view>
    <view class="quote">“{{meal.quote.text}}”</view>
    <view class="subtitle">—— {{meal.quote.from}}</view>
  </view>

  <view class="card share-meta-card">
    <view class="subtitle">海报模板：{{posterTheme}} · 文案风格：{{copyStyle}}</view>
    <view class="subtitle" style="margin-top: 6rpx;">支持“生成图片”或“直接分享到朋友圈”。</view>
  </view>

  <view class="action-stack">
    <button class="btn-primary" bindtap="openMomentsActions" loading="{{generatingPoster}}" disabled="{{generatingPoster}}">{{generatingPoster ? '生成中...' : '分享到朋友圈'}}</button>
    <button class="btn-secondary" bindtap="copyShareText">复制分享文案</button>
    <button class="btn-secondary" bindtap="pickAgain">再翻一页</button>
    <button class="btn-secondary" bindtap="toRecommend">回推荐页</button>
  </view>

  <canvas canvas-id="sharePosterCanvas" class="poster-canvas"></canvas>
</view>

<view class="container" wx:else>
  <view class="card">
    <view class="subtitle">还没有选择结果，先去推荐页看看～</view>
  </view>
  <button class="btn-primary" bindtap="toRecommend">去推荐页</button>
</view>
