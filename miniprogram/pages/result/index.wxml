<view class="container result-page" wx:if="{{meal}}">
  <view class="card result-hero">
    <image class="cover" src="{{meal.image}}" mode="aspectFill"></image>
    <view class="mask"></view>
    <view class="hero-content">
      <view class="hero-badge">今日餐案</view>
      <view class="meal-title">{{meal.title}}</view>
      <view class="subtitle hero-subtitle">{{meal.dishLine}}</view>
    </view>
  </view>

  <view class="card">
    <view class="title section-title">膳食结构</view>
    <view class="info-row">
      <view class="info-key">主食</view>
      <view class="info-value">{{meal.staple}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">蛋白</view>
      <view class="info-value">{{meal.protein}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">蔬菜</view>
      <view class="info-value">{{meal.veggie}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">补充</view>
      <view class="info-value">{{meal.extra}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">估算热量</view>
      <view class="info-value">{{meal.calories}} kcal</view>
    </view>
  </view>

  <view class="card">
    <view class="title section-title">今日诗文</view>
    <view class="quote">“{{meal.quote.text}}”</view>
    <view class="subtitle">—— {{meal.quote.from}}</view>
  </view>

  <view class="card share-meta-card">
    <view class="subtitle">海报：{{posterTheme}} · 文案：{{copyStyle}}</view>
  </view>

  <view class="action-stack">
    <button class="btn-primary" bindtap="openSharePanel">分享选项</button>
    <button class="btn-secondary" bindtap="pickAgain">再荐一席</button>
    <button class="btn-secondary" bindtap="toRecommend">返回荐食页</button>
  </view>

  <view wx:if="{{sharePanelVisible}}" class="share-sheet-mask" bindtap="closeSharePanel"></view>
  <view wx:if="{{sharePanelVisible}}" class="share-sheet">
    <view class="share-sheet-title">分享体例</view>
    <button class="btn-primary" bindtap="choosePosterThemeThenGenerate" loading="{{generatingPoster}}" disabled="{{generatingPoster}}">{{generatingPoster ? '海报绘制中...' : '分享雅集海报'}}</button>
    <button class="btn-secondary" open-type="share" bindtap="onTapShareMiniProgram">转发小程序名片</button>
    <button class="btn-secondary" bindtap="chooseCopyStyleThenShare">朋友圈文案</button>
    <button class="btn-secondary" bindtap="copyShareText">复制文案</button>
    <button class="btn-secondary" bindtap="closeSharePanel">收起</button>
  </view>

  <canvas canvas-id="sharePosterCanvas" class="poster-canvas"></canvas>
</view>

<view class="container" wx:else>
  <view class="card">
    <view class="subtitle">尚未生成餐案。</view>
  </view>
  <button class="btn-primary" bindtap="toRecommend">前往荐食页</button>
</view>
