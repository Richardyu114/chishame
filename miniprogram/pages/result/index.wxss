.result-page {
  min-height: 100vh;
}

.result-hero {
  height: 438rpx;
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 0;
}

.cover-art {
  position: absolute;
  inset: 0;
}

.cover-grain {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 6px 6px;
  opacity: 0.14;
}

.mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 20, 18, 0.08), rgba(20, 22, 20, 0.72));
}

.hero-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  background: rgba(198, 169, 105, 0.28);
  border: 1rpx solid rgba(224, 198, 142, 0.64);
  font-size: 20rpx;
}

.meal-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: rgba(248, 248, 246, 0.94);
}

.section-title {
  font-size: 32rpx;
}

.info-row {
  margin-top: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #eee7d8;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-key {
  color: #6b6b6b;
}

.info-value {
  color: #1f1f1f;
  font-weight: 600;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.quote {
  margin-top: 12rpx;
  line-height: 1.66;
  color: #2f302d;
}

.share-meta-card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.share-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 12, 12, 0.42);
  z-index: 88;
}

.share-sheet {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  border-radius: 30rpx;
  background: #fcfbf8;
  border: 1rpx solid #e6dfce;
  box-shadow: 0 -10rpx 34rpx rgba(0, 0, 0, 0.18);
  padding: 22rpx;
  z-index: 89;
}

.share-sheet-title {
  font-size: 30rpx;
  color: #1f1f1f;
  font-weight: 600;
  letter-spacing: 0.4rpx;
}

.share-sheet .btn-secondary,
.share-sheet .btn-primary {
  margin-top: 10rpx;
}

.copy-panel {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f6f2e9;
  border: 1rpx solid #e4dbc9;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.5);
}

.copy-panel-head {
  align-items: center;
  gap: 10rpx;
}

.copy-panel-title {
  flex: 1;
  color: #4b4538;
  font-size: 23rpx;
  font-weight: 600;
}

.copy-style-btn {
  margin-top: 0 !important;
  min-width: 132rpx;
  padding: 8rpx 12rpx;
  font-size: 21rpx;
  line-height: 1.1;
}

.copy-panel-text {
  margin-top: 10rpx;
  color: #2d2b27;
  font-size: 24rpx;
  line-height: 1.66;
  white-space: pre-line;
}

.copy-panel-actions {
  margin-top: 12rpx;
  gap: 12rpx;
}

.poster-canvas {
  position: fixed;
  left: -3000rpx;
  top: -3000rpx;
  width: 1500px;
  height: 2668px;
  opacity: 0;
  pointer-events: none;
}
