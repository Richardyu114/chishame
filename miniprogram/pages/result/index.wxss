.result-page {
  min-height: 100vh;
}

.result-hero {
  height: 438rpx;
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  padding: 0;
}

.cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 20, 18, 0.14), rgba(20, 22, 20, 0.72));
}

.hero-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  border-radius: 999rpx;
  padding: 5rpx 13rpx;
  background: rgba(198, 169, 105, 0.26);
  border: 1rpx solid rgba(224, 198, 142, 0.6);
  font-size: 20rpx;
}

.meal-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: rgba(248, 248, 246, 0.94);
}

.section-title {
  font-size: 32rpx;
}

.info-row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-key {
  color: #6b6b6b;
}

.info-value {
  color: #1f1f1f;
  font-weight: 600;
}

.quote {
  margin-top: 12rpx;
  line-height: 1.66;
  color: #2f302d;
}

.share-meta-card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.poster-canvas {
  position: fixed;
  left: -3000rpx;
  top: -3000rpx;
  width: 750px;
  height: 1334px;
  opacity: 0;
  pointer-events: none;
}
