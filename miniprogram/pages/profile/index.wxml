<view class="container profile-page" wx:if="{{profile}}">
  <view class="card">
    <view class="title section-title">荐食设定</view>
    <view class="subtitle drift-hint">{{flavorDriftHint}}</view>

    <view class="subtitle" style="margin-top: 14rpx;">风味偏好</view>
    <picker mode="selector" range="{{flavorOptions}}" value="{{flavorIndex}}" bindchange="onFlavorChange">
      <view class="btn-secondary flavor-pill">{{profile.preferredFlavor}}</view>
    </picker>

    <view class="subtitle" style="margin-top: 16rpx;">用餐时段</view>
    <picker mode="selector" range="{{mealModeOptions}}" value="{{mealModeIndex}}" bindchange="onMealModeChange">
      <view class="btn-secondary flavor-pill">{{profile.mealMode || '智能'}}</view>
    </picker>

    <view class="subtitle" style="margin-top: 18rpx;">忌口</view>
    <view class="taboo-wrap">
      <block wx:for="{{tabooOptions}}" wx:key="*this">
        <text class="tag {{profile.tabooTags.includes(item) ? 'active' : ''}}" data-tag="{{item}}" bindtap="toggleTaboo">{{item}}</text>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="row log-head">
      <view class="title section-title">近时记录</view>
      <button size="mini" class="btn-secondary" bindtap="clearLogs">清除</button>
    </view>

    <block wx:if="{{logs.length === 0}}">
      <view class="subtitle">暂未留下记录</view>
    </block>

    <block wx:for="{{logs}}" wx:key="ts">
      <view class="log-item">
        <view class="log-title">{{item.mealTitle || item.placeName}} · {{item.actionLabel}}</view>
        <view class="subtitle">{{item.tags ? item.tags.join('、') : ''}}</view>
      </view>
    </block>
  </view>
</view>
