<view class="container" wx:if="{{profile}}">
  <view class="card">
    <view class="title" style="font-size: 34rpx;">吃啥么设置</view>
    <view class="subtitle">偏好口味</view>
    <picker mode="selector" range="{{flavorOptions}}" value="{{flavorIndex}}" bindchange="onFlavorChange">
      <view class="btn-secondary" style="display:inline-block; margin-top:12rpx;">{{profile.preferredFlavor}}</view>
    </picker>

    <view class="subtitle" style="margin-top: 18rpx;">不吃/少吃</view>
    <view style="margin-top: 10rpx;">
      <block wx:for="{{tabooOptions}}" wx:key="*this">
        <text class="tag {{profile.tabooTags.includes(item) ? 'active' : ''}}" data-tag="{{item}}" bindtap="toggleTaboo">{{item}}</text>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="row">
      <view class="title" style="font-size: 34rpx;">最近记录</view>
      <button size="mini" class="btn-secondary" bindtap="clearLogs">清空</button>
    </view>

    <block wx:if="{{logs.length === 0}}">
      <view class="subtitle">暂无记录</view>
    </block>

    <block wx:for="{{logs}}" wx:key="ts">
      <view style="margin-top: 12rpx; border-bottom: 1rpx solid #f3f4f6; padding-bottom: 10rpx;">
        <view>{{item.mealTitle || item.placeName}} · {{item.action}}</view>
        <view class="subtitle">{{item.tags ? item.tags.join('、') : ''}}</view>
      </view>
    </block>
  </view>
</view>
