<view class="container">
  <view class="card">
    <view class="title">吃啥么</view>
    <view class="subtitle">不纠结去哪吃，先帮你定今天吃什么</view>
  </view>

  <view class="card">
    <view class="title" style="font-size: 32rpx;">口味偏好</view>
    <view class="subtitle">先选一个默认风格，后面可随时改</view>
    <picker mode="selector" range="{{flavors}}" value="{{flavorIndex}}" bindchange="onFlavorChange">
      <view class="btn-secondary" style="display:inline-block; margin-top:14rpx;">{{flavors[flavorIndex]}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="title" style="font-size: 32rpx;">不吃/少吃（可选）</view>
    <view style="margin-top: 16rpx;">
      <block wx:for="{{allTabooTags}}" wx:key="*this">
        <text class="tag {{tabooTags.indexOf(item) >= 0 ? 'active' : ''}}" data-tag="{{item}}" bindtap="toggleTaboo">{{item}}</text>
      </block>
    </view>
  </view>

  <button class="btn-primary" bindtap="saveAndStart">开始抽今天吃什么</button>
</view>
