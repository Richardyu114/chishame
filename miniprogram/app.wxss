/*
  Chishame Design Tokens (v0.5)
  - Background: #F7F6F2
  - Text: #1F1F1F
  - Muted: #6B6B6B
  - Primary: #2F5D50
  - Accent: #C6A969
*/

page {
  background: #f7f6f2;
  color: #1f1f1f;
  font-size: 28rpx;
  font-family: "HarmonyOS Sans SC", "MiSans", "PingFang SC", "Hiragino Sans GB", "Source Han Sans SC", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 24rpx;
  padding-bottom: 34rpx;
}

.card {
  background: #fcfbf8;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #ece8dd;
  box-shadow: 0 12rpx 30rpx rgba(47, 53, 46, 0.08);
  margin-bottom: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  font-family: "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "Songti SC", serif;
}

.subtitle {
  color: #6b6b6b;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  letter-spacing: 0.2rpx;
}

button {
  line-height: 1.2;
  border: none;
  font-family: "HarmonyOS Sans SC", "MiSans", "PingFang SC", "Hiragino Sans GB", "Source Han Sans SC", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
  font-weight: 560;
  letter-spacing: 0.3rpx;
  transition: transform 120ms ease, filter 120ms ease, box-shadow 120ms ease, opacity 120ms ease;
}

button::after {
  border: none;
}

button[disabled] {
  opacity: 0.62;
  filter: saturate(0.75);
}

.btn-pressed {
  transform: scale(0.97);
  filter: brightness(0.96);
}

.btn-primary {
  background: #2f5d50;
  color: #fff;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  text-align: center;
  border: 1rpx solid #2a5146;
  box-shadow: 0 10rpx 20rpx rgba(47, 93, 80, 0.24);
}

.btn-secondary {
  background: #f2efe7;
  color: #2f5d50;
  border: 1rpx solid #dbd3c1;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3efe5;
  color: #5f5a4f;
  border: 1rpx solid #e4ddcd;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  font-size: 22rpx;
}

.tag.active {
  background: #2f5d50;
  color: #fff;
  border-color: #2a5146;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #6b6b6b;
}
