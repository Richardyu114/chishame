page {
  background: #ffffff;
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #f3f4f6;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 0.3rpx;
}

.subtitle {
  color: #6b7280;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.btn-primary {
  background: #f97316;
  color: #fff;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(249, 115, 22, 0.25);
}

.btn-secondary {
  background: #fff7ed;
  color: #ea580c;
  border: 2rpx solid #fdba74;
  border-radius: 999rpx;
  padding: 14rpx 24rpx;
  text-align: center;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #9a3412;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  font-size: 22rpx;
}

.tag.active {
  background: #f97316;
  color: #fff;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #6b7280;
}
